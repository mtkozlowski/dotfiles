# --- macOS GUI app CLIs (only on Macs that actually have these installed) -----

# LM Studio
# [[ -d "$HOME/.lmstudio/bin" ]] && export PATH="$PATH:$HOME/.lmstudio/bin"

# JetBrains Toolbox
# [[ -d "$HOME/Library/Application Support/JetBrains/Toolbox/scripts" ]] && \
#     export PATH="$PATH:$HOME/Library/Application Support/JetBrains/Toolbox/scripts"

# Obsidian CLI
# [[ -d "/Applications/Obsidian.app/Contents/MacOS" ]] && \
#     export PATH="$PATH:/Applications/Obsidian.app/Contents/MacOS"

# Sublime Text
# [[ -d "/Applications/Sublime Text.app/Contents/SharedSupport/bin" ]] && \
#     export PATH="/Applications/Sublime Text.app/Contents/SharedSupport/bin:$PATH"

# --- Other per-machine tools --------------------------------------------------

# opencode
# [[ -d "$HOME/.opencode/bin" ]] && export PATH="$HOME/.opencode/bin:$PATH"

# --- gh-dash per-host config --------------------------------------------------
# gh-dash reads one config.yml. To keep section/theme/keybindings shared but
# `repoPaths:` host-specific, the active config is assembled from
# config.base.yml + repoPaths.<host>.yml at shell startup. Uncomment the
# anonymous function for THIS machine's flavour.
#
# Private work repo paths go in an untracked gh-dash/repoPaths.local.yml (gitignored,
# kept in the companion repo); the assembly appends it automatically if present.
#
