#     return 1
#   fi
#   mkdir -p "${out:h}"
#   local frags=("$d/config.base.yml" "$d/repoPaths.linux.yml")
#   [[ -r "$d/repoPaths.local.yml" ]] && frags+=("$d/repoPaths.local.yml")
#   cat "${frags[@]}" > "$out"
#   export GH_DASH_CONFIG="$out"
# }
