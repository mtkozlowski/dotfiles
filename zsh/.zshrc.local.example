# --- Secrets ------------------------------------------------------------------
# Fetch credentials from a secret manager at shell init — never hard-code them.
# 1Password CLI (op) example; gate on the binary so machines without op don't error:
# command -v op >/dev/null && export OPENAI_API_KEY="$(op read 'op://Private/OpenAI/credential')"
#
# Alternatives: pass (`export KEY="$(pass show api/openai)"`), sops+age, macOS Keychain.
# Last resort only (avoid — leaks into env/history): export OPENAI_API_KEY="sk-..."
