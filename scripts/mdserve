#!/usr/bin/env python3
"""
mdserve — a tiny, self-hosted file browser that renders Markdown nicely and
works well on a phone.

Standard library only. No pip install. Drop it on your VPS and run:

    mdserve                      # serve current dir on 0.0.0.0:8080
    mdserve --root /srv/agent    # serve a specific directory
    mdserve --port 9000
    mdserve --user me            # require Basic auth (prompts for password)

Then open http://YOUR_VPS_IP:8080/ on your phone.

Markdown/code rendering (marked + highlight.js + DOMPurify) is loaded from a
CDN, so the *viewing device* needs internet — which your phone has when it
reaches the VPS. If a lib fails to load, the raw text is shown instead.

SECURITY NOTES
- Binds 0.0.0.0 by default: anyone who can reach the port reads every file
  under --root. Use --user/--password, or restrict exposure with a firewall.
- Basic auth is sent in cleartext over plain HTTP. Only expose this over a
  trusted network — e.g. a WireGuard/SSH tunnel or Tailscale, not the open
  internet. Prefer MDSERVE_PASSWORD (env) over --password so the secret does
  not leak into `ps`/shell history.
"""

import argparse
import datetime as _dt
import getpass
import hmac
import html
import json
import mimetypes
import os
import posixpath
import socket
import urllib.parse
from base64 import b64decode
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

# ----------------------------------------------------------------------------
# Config (populated in main())
# ----------------------------------------------------------------------------
ROOT = os.getcwd()
SHOW_HIDDEN = False
AUTH = None  # (user, password) tuple, or None
INLINE_MAX = 3 * 1024 * 1024  # render text/markdown inline up to this size

MD_EXTS = {".md", ".markdown", ".mdown", ".mkd", ".mkdn", ".mdwn"}
IMG_EXTS = {".png", ".jpg", ".jpeg", ".gif", ".webp", ".svg", ".bmp", ".ico", ".avif"}
TEXT_EXTS = {
    ".txt", ".text", ".log", ".csv", ".tsv", ".json", ".yaml", ".yml", ".toml",
    ".ini", ".cfg", ".conf", ".env", ".sh", ".bash", ".zsh", ".fish", ".ps1",
    ".py", ".pyi", ".js", ".mjs", ".cjs", ".ts", ".tsx", ".jsx", ".css", ".scss",
    ".less", ".html", ".htm", ".xml", ".sql", ".rb", ".go", ".rs", ".c", ".h",
    ".cpp", ".hpp", ".cc", ".java", ".kt", ".swift", ".php", ".pl", ".lua",
    ".r", ".jl", ".dart", ".scala", ".clj", ".ex", ".exs", ".erl", ".hs",
    ".dockerfile", ".makefile", ".gitignore", ".editorconfig", ".diff", ".patch",
}

CDN = "https://cdnjs.cloudflare.com/ajax/libs"

# ----------------------------------------------------------------------------
# Styling — a calm "reader" theme, light + dark via prefers-color-scheme.
# Accent is a muted cyan/teal, a nod to terminal output without the cliches.
# ----------------------------------------------------------------------------
