.DS_Store
fzf
history.txt

# Python bytecode cache (e.g. from importing scripts/mdserve for testing).
__pycache__/
*.pyc
tmux/plugins/
zsh/.zcompdump*
zsh/.zsh_history
zsh/plugins/
zsh/.zsh_sessions

# Machine-specific installer receipt (regenerated by the atuin installer).
atuin/atuin-receipt.json

# Homebrew tap-trust runtime state (rewritten by brew; the Brewfile already
# pins `trusted: true` taps, so tracking this is redundant and churny).
homebrew/trust.json
homebrew/trust.json.lock

# Per-machine overrides — tracked file is the *.local.example template only.
*.local
!*.local.example
**/.a5c/**

# Private overlay — never published. Real content lives in the companion repo /
# secret manager; these are surfaced locally via the folded stow symlink.
# (See README "Private overlay" and .githooks/markers.local.example.)
# generic home for private/machine-local shell scripts:
zsh/local/
# private gh-dash repo-path overrides (work repos):
gh-dash/repoPaths.local.yml
# personal pre-commit marker regexes:
.githooks/markers.local

gh/hosts.yml
ghostty/ghostty-shaders
worktrunk/config.toml.lock
